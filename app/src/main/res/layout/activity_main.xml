<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Busca de Cartas Magic"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Digite o nome da carta:"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etNomeCarta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Black Lotus"
            android:inputType="text"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filtro de Cor:"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerCor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:entries="@array/opcoes_cores"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filtro de Tipo:"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:entries="@array/opcoes_tipos"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnBuscar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buscar Carta"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnMonitorarPreco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Criar Alerta de Preço (Notificação)"
            android:layout_marginTop="8dp"
            android:backgroundTint="#4CAF50" />

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A carta aparecerá aqui..."
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>

        <ImageView
            android:id="@+id/ivCarta"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginTop="16dp"
            android:scaleType="fitCenter"/>

    </LinearLayout>
</ScrollView>